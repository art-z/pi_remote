# --- HTTP ---
HTTP_PORT=80

# Общий Redis (внутри compose не меняйте хост без правки docker-compose)
REDIS_URL=redis://redis:6379/0

# Ключи очереди и дисплея (должны совпадать у api / display / worker)
DISPLAY_STATE_KEY=display:state
DISPLAY_NOTIFY_CHANNEL=display:notify
# IANA-пояс для часов на дисплее и полей local_time / timezone в /api/status (хранится в Redis)
TIMEZONE_KEY=system:timezone
DEFAULT_TIMEZONE=Europe/Moscow
SYNC_QUEUE_KEY=sync:outbound

# Состояние вентилятора (fan_agent → api /api/status)
FAN_STATE_KEY=fan:state

# --- Синхронизация с внешним сервером ---
# Полный URL endpoint приёма JSON (POST). Пусто — воркер ждёт и не шлёт.
REMOTE_SYNC_URL=
REMOTE_SYNC_TOKEN=
REMOTE_SYNC_TIMEOUT_SEC=15

# Автоматическая телеметрия в очередь (api → Redis LIST → worker)
SYNC_AUTO=false
SYNC_INTERVAL_SEC=60

# --- API ---
CORS_ORIGINS=*
CPU_TEMP_SYSFS=/sys/class/thermal/thermal_zone0/temp

# --- Дисплей ST7789 (luma; см. prev/display.py и prev/app.py) ---
DISPLAY_SPI_PORT=0
DISPLAY_SPI_DEVICE=0
DISPLAY_GPIO_DC=27
DISPLAY_GPIO_RST=22
# luma: 0=0°, 1=90°, 2=180°, 3=270°. В prev/display.py было rotation=180 → 2
DISPLAY_ROTATE=2
# Базовый кегль (пока нет записи в Redis); дальше — из веб-интерфейса, ключ font_size в display:state
DISPLAY_FONT_SIZE=17
DISPLAY_WIDTH=240
DISPLAY_HEIGHT=240
# Как prev/display.py spi_speed_hz=80_000_000
DISPLAY_SPI_SPEED_HZ=80000000
# Подсветка: в luma по умолчанию GPIO 18. Явно задать — например если конфликт с I2S или своя разводка BL (см. services/display/README.md).
# DISPLAY_GPIO_LIGHT=18
DISPLAY_FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
DISPLAY_PULSE_FRAME_SEC=0.08
DISPLAY_STATUS_POLL_SEC=0.35

# --- Вентилятор PWM (docker compose --profile fan; как scripts/fan_control_pwm.py) ---
# BCM 13, 25 Гц, линейная шкала duty между TEMP_MIN и TEMP_MAX
FAN_GPIO=13
FAN_PWM_HZ=25
FAN_TEMP_MIN=40
FAN_TEMP_MAX=65
FAN_CHECK_INTERVAL_SEC=5

# --- Аудио / STT (Vosk small-ru, ALSA → Redis display:state) ---
# Каталог на хосте с распакованной моделью (в контейнере → /opt/vosk-model). Скачивание: models/README.md
# VOSK_MODEL_HOST_DIR=./models/vosk-model-small-ru-0.22
# Устройство захвата: на Pi часто default или plughw:CARD,DEVICE — см. arecord -l на хосте
AUDIO_ALSA_DEVICE=default
# Путь внутри контейнера (не меняйте, если не меняете mount в docker-compose)
AUDIO_MODEL_PATH=/opt/vosk-model
# Частота и размер чанка для Vosk (не меняйте без смены модели)
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_BYTES=8000
# Не чаще, чем раз в N сек публиковать частичный текст в Redis (меньше нагрузка на дисплей)
AUDIO_PARTIAL_PUBLISH_SEC=0.25
# Как отрисовывать на дисплее: pulse | status
AUDIO_DISPLAY_MODE=pulse
# История финальных фраз в Redis LIST (ключ AUDIO_HISTORY_KEY), не дольше AUDIO_HISTORY_MAX записей
AUDIO_STORE_HISTORY=true
AUDIO_HISTORY_KEY=audio:history
AUDIO_HISTORY_MAX=500
# Класть события в ту же очередь, что sync-worker (SYNC_QUEUE_KEY), только если задан REMOTE_SYNC_URL
AUDIO_PUSH_TO_SYNC_QUEUE=true
